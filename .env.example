# AgentAuth environment variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# ============================================================
# Server
# ============================================================
AGENTAUTH_HOST=0.0.0.0
AGENTAUTH_PORT=8080
AGENTAUTH_LOG_LEVEL=info

# ============================================================
# Database (PostgreSQL 16+)
# ============================================================
AGENTAUTH_POSTGRES_DSN=postgres://agentauth:password@localhost:5432/agentauth?sslmode=disable

# ============================================================
# Cache (Redis 7+)
# ============================================================
AGENTAUTH_REDIS_ADDR=localhost:6379
AGENTAUTH_REDIS_PASSWORD=
AGENTAUTH_REDIS_DB=0

# ============================================================
# Messaging (NATS)
# ============================================================
AGENTAUTH_NATS_URL=nats://localhost:4222

# ============================================================
# Identity
# ============================================================
AGENTAUTH_TRUST_DOMAIN=agentauth.io
AGENTAUTH_CA_CERT_FILE=/etc/agentauth/ca.crt
AGENTAUTH_SIGNING_KEY_FILE=/etc/agentauth/signing.key

# ============================================================
# Security
# ============================================================
# JWT signing key (HMAC-SHA256) — generate with: openssl rand -hex 32
AGENTAUTH_JWT_SIGNING_KEY=

# API key hash (bcrypt or argon2id hash of your API key)
AGENTAUTH_API_KEY_HASH=

# ============================================================
# Observability
# ============================================================
AGENTAUTH_OTLP_ENDPOINT=
AGENTAUTH_METRICS_PORT=9090

# ============================================================
# Client (for CLI and SDK usage)
# ============================================================
AGENTAUTH_SERVER_URL=http://localhost:8080
AGENTAUTH_API_KEY=

# ============================================================
# Docker Compose (postgres password override)
# ============================================================
POSTGRES_PASSWORD=agentauth
